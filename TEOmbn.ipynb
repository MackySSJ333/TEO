import numpy as np
import matplotlib.pyplot as plt
import networkx as nx
import pandas as pd
import string
import os

# --- Carga desde CSV ---
def load_matrix_from_csv(prompt_text):
    """
    Solicita la ruta de un archivo CSV y carga la matriz, nombres de filas y columnas.
    """
    while True:
        path = input(f"{prompt_text} (ruta/archivo.csv): ").strip()
        # Eliminar comillas si el usuario copió la ruta como "ruta"
        path = path.replace('"', '').replace("'", "")

        if os.path.exists(path):
            try:
                # index_col=0 usa la primera columna como etiquetas de fila
                df = pd.read_csv(path, index_col=0)

                # Validar que sea numérico
                # Coercemos a numérico, los errores se vuelven NaN y luego 0
                df = df.apply(pd.to_numeric, errors='coerce').fillna(0)

                # Validar rango borroso [0, 1]
                if (df.values > 1).any() or (df.values < 0).any():
                    print("Advertencia: Se encontraron valores fuera del rango [0, 1]. Se recortarán.")
                    df = df.clip(0, 1)

                return df.values, list(df.index), list(df.columns)
            except Exception as e:
                print(f"Error al leer el CSV: {e}")
        else:
            print("Error: El archivo no existe. Verifique la ruta.")

# --- Funciones de Utilidad y Core de TEO (Sin cambios mayores) ---

def get_matrix_input(rows, cols, name_rows, name_cols, row_labels, col_labels):
    """
    Función para solicitar al usuario los datos de una matriz borrosa.
    Utiliza nombres de conjuntos y etiquetas de elementos personalizadas.
    """
    matrix = np.zeros((rows, cols))
    print(f"\n--- Matriz de Incidencia: {name_rows} ({rows}) -> {name_cols} ({cols}) ---")
    for i in range(rows):
        for j in range(cols):
            while True:
                try:
                    # Uso de las etiquetas de los elementos para la solicitud (e.g., 'Economía' -> 'Población')
                    prompt = f"  Incidencia de '{row_labels[i]}' sobre '{col_labels[j]}': "
                    value = float(input(prompt))

                    if 0 <= value <= 1:
                        matrix[i, j] = value
                        break
                    else:
                        print("Error: El valor debe ser un número borroso (entre 0 y 1). Intente de nuevo.")
                except ValueError:
                    print("Error: Ingrese solo valores numéricos. Intente de nuevo.")
    return matrix

def max_min_composition(matrix1, matrix2):
    """
    Realiza la operación de composición max-min entre dos matrices borrosas.
    Devuelve la matriz resultante y una estructura de datos con los pasos para la tabla.
    """
    rows1, cols1 = matrix1.shape
    rows2, cols2 = matrix2.shape

    if cols1 != rows2:
        raise ValueError("Las dimensiones de las matrices no son compatibles para la composición.")

    result_matrix = np.zeros((rows1, cols2))
    composition_steps = []

    # Algoritmo de composición max-min (V(A))
    for i in range(rows1):
        for k in range(cols2):
            max_val = 0
            steps_jk = []

            for j in range(cols1):
                # Operador 'min' (∧)
                min_val = min(matrix1[i, j], matrix2[j, k])
                steps_jk.append((matrix1[i, j], matrix2[j, k], min_val))

                # Operador 'max' (V)
                if min_val > max_val:
                    max_val = min_val

            result_matrix[i, k] = max_val
            composition_steps.append({'i': i, 'k': k, 'steps': steps_jk, 'result': max_val})

    return result_matrix, composition_steps

def subtract_matrices(matrix_m2, matrix_m1):
    """
    Calcula la matriz de Efectos Olvidados (2° Generación): M'2 = M2 - M1.
    """
    if matrix_m2.shape != matrix_m1.shape:
        raise ValueError("Las matrices deben tener las mismas dimensiones para la resta.")

    # Resta de matrices borrosas. Aseguramos no negatividad, aunque M1 C M2 es común en TEO.
    result_matrix = np.maximum(0, matrix_m2 - matrix_m1)

    return result_matrix

def print_matrix(matrix, title, row_labels=None, col_labels=None):
    """
    Imprime una matriz utilizando pandas para un formato legible con etiquetas.
    """
    print(f"\n--- {title} ---")

    # Si no se proporcionan etiquetas, usa índices numéricos
    if row_labels is None:
        row_labels = [f"r{i+1}" for i in range(matrix.shape[0])]
    if col_labels is None:
        col_labels = [f"c{j+1}" for j in range(matrix.shape[1])]

    df = pd.DataFrame(matrix, index=row_labels, columns=col_labels)
    # Se utiliza formato de 3 decimales para valores borrosos
    print(df.to_string(float_format="{:.3f}".format))

def draw_incidence_graph(matrix, source_labels, target_labels, title):
    """
    Dibuja un grafo de incidencia bipartito a partir de una matriz borrosa.
    """
    G = nx.DiGraph()

    # Creación de nodos con prefijos para distinguir los conjuntos
    source_nodes = [f"S_{label}" for label in source_labels]
    target_nodes = [f"T_{label}" for label in target_labels]

    G.add_nodes_from(source_nodes, bipartite=0)
    G.add_nodes_from(target_nodes, bipartite=1)

    # Posicionamiento (bipartito vertical)
    pos = {}
    pos.update((node, (1, -i)) for i, node in enumerate(source_nodes))
    pos.update((node, (2.5, -i)) for i, node in enumerate(target_nodes)) # Separación horizontal mayor

    edge_labels = {}
    for i, s_label in enumerate(source_labels):
        s_node = source_nodes[i]
        for j, t_label in enumerate(target_labels):
            t_node = target_nodes[j]
            weight = matrix[i, j]
            if weight > 0: # Solo dibuja si hay incidencia
                G.add_edge(s_node, t_node, weight=weight)
                edge_labels[(s_node, t_node)] = f"{weight:.3f}"

    plt.figure(figsize=(10, 8))

    nx.draw_networkx_nodes(G, pos, nodelist=source_nodes, node_color='skyblue', node_size=1200)
    nx.draw_networkx_nodes(G, pos, nodelist=target_nodes, node_color='lightgreen', node_size=1200)

    # Las etiquetas de los nodos muestran los nombres completos
    labels = {node: node.split('_')[1] for node in G.nodes()}
    nx.draw_networkx_labels(G, pos, labels=labels, font_size=10)

    nx.draw_networkx_edges(G, pos, arrowstyle='->', arrowsize=20, node_size=1200)
    nx.draw_networkx_edge_labels(G, pos, edge_labels=edge_labels, font_color='darkred', font_size=9)

    plt.title(title, fontsize=16)
    plt.box(False)
    plt.show(block=False)

def print_composition_tables(steps, set_names, A_labels, B_labels, C_labels):
    """
    Imprime la tabla explicativa de la composición Max-Min (A -> B -> C).
    """
    print("\n\n================== TABLA DE COMPOSICIÓN MAX-MIN (A -> B -> C) ==================")

    # Columnas dinámicas para la tabla
    b_cols = [f"min(Inc({A_labels[0]}->{b_label}), Inc({b_label}->{C_labels[0]}))" for b_label in B_labels]

    # Generar una tabla por cada incidencia (A_i -> C_k)
    for step_data in steps:
        i = step_data['i']
        k = step_data['k']

        a_label = A_labels[i]
        c_label = C_labels[k]

        print(f"\n--- Cálculo de la Incidencia de '{a_label}' sobre '{c_label}' ---")

        # Preparar datos de la fila
        table_data = []
        for j, (val_AB, val_BC, val_min) in enumerate(step_data['steps']):
            b_label = B_labels[j]
            # [i][j] en R_AB, [j][k] en R_BC, min, max

            row = {
                f"Elemento de {set_names[1]}": b_label,
                f"Incidencia {set_names[0]}->{set_names[1]}": f"{val_AB:.3f}",
                f"Incidencia {set_names[1]}->{set_names[2]}": f"{val_BC:.3f}",
                "Valor min (∧)": f"{val_min:.3f}",
            }
            table_data.append(row)

        df = pd.DataFrame(table_data)

        # Agregar la fila de resultado (Máximo)
        max_row = {
            f"Elemento de {set_names[1]}": "Resultado (Máx V):",
            f"Incidencia {set_names[0]}->{set_names[1]}": "",
            f"Incidencia {set_names[1]}->{set_names[2]}": "",
            "Valor min (∧)": f"{step_data['result']:.3f}",
        }
        df.loc[len(df)] = max_row

        print(df.to_string(index=False))

def get_set_info(num_sets):
    """
    Solicita al usuario los nombres de los conjuntos y los nombres de sus elementos.
    """
    set_dims = []
    set_names_custom = []
    labels_sets = []

    alphabet_names = list(string.ascii_uppercase)

    print("\n--- INGRESO DE INFORMACIÓN DE CONJUNTOS ---")
    for i in range(num_sets):
        base_name = alphabet_names[i]

        # 1. Nombre del Conjunto
        while True:
            name = input(f"  Ingrese el nombre del Conjunto {base_name} (ej. Causas, Efectos, Población): ")
            if name.strip():
                set_names_custom.append(name.strip())
                break
            else:
                print("Error: El nombre del conjunto no puede estar vacío.")

        # 2. Dimensión
        while True:
            try:
                dim = int(input(f"  Número de elementos en el conjunto '{set_names_custom[i]}': "))
                if dim > 0:
                    set_dims.append(dim)
                    break
                else:
                    print("Error: El número de elementos debe ser mayor a cero.")
            except ValueError:
                print("Error: Ingrese solo un número entero.")

        # 3. Etiquetas de Elementos
        element_labels = []
        print(f"  --- Etiquetas de elementos para '{set_names_custom[i]}' ---")
        for j in range(dim):
            while True:
                # Sugerencia: Conjunto_Inicial + Índice (e.g., A1, B2)
                default_label = f'{base_name}{j+1}'
                label = input(f"  Etiqueta para el elemento {j+1} (sug. '{default_label}'): ") or default_label
                if label.strip():
                    element_labels.append(label.strip())
                    break
                else:
                    print("Error: La etiqueta del elemento no puede estar vacía.")
        labels_sets.append(element_labels)

    return set_dims, set_names_custom, labels_sets
def inspect_specific_element(matrix, row_labels, col_labels, matrix_name):
    """
    Permite al usuario ingresar el nombre de un elemento (fila o columna)
    y visualiza sus relaciones específicas (tabla ordenada + grafo enfocado).
    """
    while True:
        print(f"\n--- INSPECTOR DE ELEMENTOS PARA: {matrix_name} ---")
        print("Escriba la etiqueta exacta del elemento a inspeccionar (o 'salir' para volver):")
        # Mostramos opciones disponibles para ayudar al usuario
        print(f"Opciones (Filas): {', '.join(row_labels[:5])}...")
        print(f"Opciones (Columnas): {', '.join(col_labels[:5])}...")

        target = input(">> Elemento: ").strip()
        if target.lower() == 'salir': break

        found = False

        # 1. Buscar en FILAS (El elemento actúa como CAUSA)
        if target in row_labels:
            found = True
            idx = row_labels.index(target)
            values = matrix[idx, :]

            # Crear DataFrame filtrado
            df = pd.DataFrame({'Efecto': col_labels, 'Incidencia': values})
            df = df[df['Incidencia'] > 0].sort_values(by='Incidencia', ascending=False)

            print(f"\n[ANÁLISIS] '{target}' como CAUSA en '{matrix_name}':")
            print(df.to_string(index=False))

            # Graficar sub-grafo (Outgoing)
            draw_focused_graph(target, df['Efecto'].tolist(), df['Incidencia'].tolist(),
                               f"Impactos de '{target}'", mode='source')

        # 2. Buscar en COLUMNAS (El elemento actúa como EFECTO)
        # Nota: Usamos 'elif' si los nombres son únicos, o 'if' si pueden repetirse (A->A)
        # En TEO A->A, un elemento es tanto fila como columna. Revisamos ambos.
        if target in col_labels:
            found = True
            idx = col_labels.index(target)
            values = matrix[:, idx]

            # Crear DataFrame filtrado
            df = pd.DataFrame({'Causa': row_labels, 'Incidencia': values})
            df = df[df['Incidencia'] > 0].sort_values(by='Incidencia', ascending=False)

            print(f"\n[ANÁLISIS] '{target}' como EFECTO (recibe) en '{matrix_name}':")
            print(df.to_string(index=False))

            # Graficar sub-grafo (Incoming)
            draw_focused_graph(target, df['Causa'].tolist(), df['Incidencia'].tolist(),
                               f"Causas que inciden en '{target}'", mode='target')

        if not found:
            print(f"Error: No se encontró la etiqueta '{target}' en esta matriz.")

def draw_focused_graph(center_node, connected_nodes, weights, title, mode='source'):
    """
    Dibuja un grafo 'estrella' centrado en el nodo de interés.
    mode='source': El centro dispara flechas hacia afuera.
    mode='target': El centro recibe flechas.
    """
    G = nx.DiGraph()

    # Añadir nodo central
    G.add_node(center_node, layer=0)

    edge_labels = {}

    # Añadir conexiones
    for node, w in zip(connected_nodes, weights):
        G.add_node(node, layer=1)
        if mode == 'source':
            G.add_edge(center_node, node, weight=w)
            edge_labels[(center_node, node)] = f"{w:.2f}"
        else:
            G.add_edge(node, center_node, weight=w)
            edge_labels[(node, center_node)] = f"{w:.2f}"

    pos = nx.spring_layout(G, seed=42) # Layout orgánico para grafos estrella

    plt.figure(figsize=(8, 6))

    # Dibujar Nodos
    nx.draw_networkx_nodes(G, pos, node_size=2000, node_color='lightyellow', edgecolors='black')
    nx.draw_networkx_labels(G, pos, font_size=10, font_weight='bold')

    # Dibujar Aristas
    nx.draw_networkx_edges(G, pos, arrowstyle='->', arrowsize=25, edge_color='gray')
    nx.draw_networkx_edge_labels(G, pos, edge_labels=edge_labels, font_color='red')

    plt.title(title)
    plt.axis('off')
    plt.show(block=False)

# --- MAIN REESTRUCTURADO ---

def main():
    print("### AUTOMATIZACIÓN DE EFECTOS DE ORDEN SUPERIOR (TEO) ###")

    # 1. Selección de Modo
    while True:
        try:
            print("\nModo de entrada de datos:")
            print("1. Manual (Ingresar datos paso a paso en consola)")
            print("2. Importar CSV (Cargar archivos .csv existentes)")
            mode = input("Seleccione opción (1 o 2): ").strip()
            if mode in ['1', '2']: break
        except: pass

    # 2. Selección de Orden
    while True:
        try:
            num_matrices = int(input("\nNúmero de matrices: "))
            if num_matrices in [1, 2]: break
        except ValueError: pass

    # Variables principales
    input_matrices = []
    labels_sets = []
    set_names_custom = []
    set_dims = []

    # --- LÓGICA: MODO MANUAL ---
    if mode == '1':
        num_sets = num_matrices + 1
        set_dims, set_names_custom, labels_sets = get_set_info(num_sets)

        print("\n--- LLENADO DE MATRICES ---")
        for i in range(num_matrices):
            m = get_matrix_input(set_dims[i], set_dims[i+1],
                                 set_names_custom[i], set_names_custom[i+1],
                                 labels_sets[i], labels_sets[i+1])
            input_matrices.append(m)

    # --- LÓGICA: MODO CSV ---
    elif mode == '2':
        print("\n--- IMPORTACIÓN CSV ---")
        print("Asegúrese de que el CSV tenga los nombres de filas en la primera columna y nombres de columnas en la cabecera.")

        # Necesitamos pedir nombres de los conjuntos para etiquetar los gráficos
        # Estrategia: Leemos Matrix 1. Obtenemos Sets A y B.
        # Si hay Matrix 2, leemos Matrix 2. Obtenemos Sets B' y C. Validamos que B == B'.

        # --- MATRIZ 1 ---
        print("\n>> Matriz 1 (A -> B)")
        m1, rows1, cols1 = load_matrix_from_csv("Ruta del archivo CSV para la Matriz 1")
        name_A = input("Nombre del Conjunto de FILAS (ej. Causas): ") or "Conjunto A"
        name_B = input("Nombre del Conjunto de COLUMNAS (ej. Efectos): ") or "Conjunto B"

        input_matrices.append(m1)
        labels_sets.append(rows1) # Set A
        labels_sets.append(cols1) # Set B
        set_names_custom.append(name_A)
        set_names_custom.append(name_B)

        if num_matrices == 2:
            print("\n>> Matriz 2 (B -> C)")
            m2, rows2, cols2 = load_matrix_from_csv("Ruta del archivo CSV para la Matriz 2")

            # Validación simple: Las filas de M2 deben coincidir en cantidad con columnas de M1
            if len(rows2) != len(cols1):
                print(f"ERROR: Las filas de la Matriz 2 ({len(rows2)}) no coinciden con las columnas de la Matriz 1 ({len(cols1)}).")
                print("No se puede realizar la composición.")
                return

            name_C = input("Nombre del Conjunto de COLUMNAS finales (ej. Soluciones): ") or "Conjunto C"

            input_matrices.append(m2)
            labels_sets.append(cols2) # Set C
            set_names_custom.append(name_C)

    # --- 3. LÓGICA DE PROCESAMIENTO (Igual que antes) ---

    final_result_matrix = None
    composition_steps = None
    effects_matrix = None

    # CASO 1: UNA MATRIZ (Posible A->A)
    if num_matrices == 1:
        matrix_input = input_matrices[0]
        rows, cols = matrix_input.shape

        # Si es CSV, labels_sets tiene [A, B].
        # Comprobamos si es cuadrada para autocomposición
        if rows == cols:
            print(f"\n--- MATRIZ CUADRADA DETECTADA ({rows}x{cols}) ---")
            print("Calculando automáticamente M ∘ M y Efectos Olvidados (M^2 - M).")

            final_result_matrix, composition_steps = max_min_composition(matrix_input, matrix_input)
            final_title = f"Incidencia 2° Orden (Auto) ({set_names_custom[0]})"

            effects_matrix = subtract_matrices(final_result_matrix, matrix_input)
            effects_title = f"Efectos Olvidados (M^2 - M)"
        else:
            print(f"\n--- Matriz Rectangular ({rows}x{cols}) ---")
            print("Solo se mostrará la incidencia directa.")
            final_result_matrix = matrix_input
            final_title = f"Matriz Directa ({set_names_custom[0]} -> {set_names_custom[1]})"

    # CASO 2: DOS MATRICES (A->B->C)
    elif num_matrices == 2:
        print(f"\n--- Composición A->B->C ---")
        matrix_rab = input_matrices[0]
        matrix_rbc = input_matrices[1]

        final_result_matrix, composition_steps = max_min_composition(matrix_rab, matrix_rbc)
        final_title = f"Matriz 2° Orden ({set_names_custom[0]} -> {set_names_custom[-1]})"

        # Preguntar por matriz directa M1 (para calcular efectos olvidados)
        print("\n¿Desea calcular Efectos Olvidados (Restar una M1 directa)?")
        if mode == '2':
            print("Puede cargar un CSV para M1, o presionar Enter para omitir.")
            path_m1 = input("Ruta CSV para M1 Directa (o Enter para omitir): ")
            if path_m1.strip():
                try:
                    m1_direct, _, _ = load_matrix_from_csv(path_m1)  # Reusamos la lógica de carga, ignoramos labels
                    # Ajuste si es función interna, aquí llamamos a la lógica interna de pandas
                    # Mejor llamamos a la función helper arriba si el usuario pone path
                    # NOTA: Como la función load_matrix_from_csv pide input dentro, hacemos un pequeño hack o simplemente la llamamos
                    # Para simplificar, asumiremos que si pone algo, intentamos cargar.
                    pass
                except: pass
                # Corrección lógica para el flujo:
                # Mejor preguntamos s/n y luego pedimos ruta.

        choice = input("¿Existe matriz directa M1? (s/n): ").lower()
        if choice == 's':
            if mode == '1': # Manual
                m1_direct = get_matrix_input(input_matrices[0].shape[0], input_matrices[1].shape[1],
                                             "Directa M1", "Fin", labels_sets[0], labels_sets[-1])
            else: # CSV
                m1_direct, _, _ = load_matrix_from_csv("Ruta CSV de Matriz Directa M1")

            # Validar dimensiones antes de restar
            if m1_direct.shape == final_result_matrix.shape:
                effects_matrix = subtract_matrices(final_result_matrix, m1_direct)
                effects_title = "Matriz Efectos Olvidados"
            else:
                print("Error: Las dimensiones de M1 no coinciden con el resultado.")

    # --- 4. RESULTADOS (Print y Plot) ---
    print("\n\n=== RESULTADOS ===")

    # Matrices Originales
    for i, m in enumerate(input_matrices):
        print_matrix(m, f"Matriz Original {i+1}", labels_sets[i], labels_sets[i+1])
        draw_incidence_graph(m, labels_sets[i], labels_sets[i+1], f"Grafo Original {i+1}")

    # Resultado Composición
    if final_result_matrix is not None:
        # Etiquetas: Inicio -> Fin
        l_start = labels_sets[0]
        l_end = labels_sets[-1]
        print_matrix(final_result_matrix, final_title, l_start, l_end)
        draw_incidence_graph(final_result_matrix, l_start, l_end, final_title)

    # Efectos Olvidados
    if effects_matrix is not None:
        print_matrix(effects_matrix, effects_title, l_start, l_end)
        draw_incidence_graph(effects_matrix, l_start, l_end, effects_title)

    # Tabla detallada (Solo si hubo composición)
    if composition_steps:
        # Determinar etiquetas intermedias
        # Si es Caso 1 (A->A): labels_sets tiene [A, A] -> Intermedio es A
        # Si es Caso 2 (A->B->C): labels_sets tiene [A, B, C] -> Intermedio es B
        mid_labels = labels_sets[1] if num_matrices == 2 else labels_sets[0]
        # Nombres conjuntos
        names_for_table = set_names_custom if num_matrices == 2 else [set_names_custom[0], set_names_custom[0], set_names_custom[0]]

        print_composition_tables(composition_steps, names_for_table, labels_sets[0], mid_labels, labels_sets[-1])
# ... (Después de mostrar tablas y grafos generales) ...

    # --- 7. INSPECTOR INTERACTIVO ---
    while True:
        print("\n\n=== MODO INSPECTOR ===")
        print("¿Desea examinar un elemento en detalle?")
        print("1. Inspeccionar Matriz de Resultados (M2 o Composición)")
        print("2. Inspeccionar Matriz de Efectos Olvidados (si existe)")
        print("0. Salir / Finalizar programa")

        opc = input("Seleccione opción: ").strip()

        if opc == '1':
            if final_result_matrix is not None:
                # Determinar etiquetas correctas
                l_rows = labels_sets[0]
                l_cols = labels_sets[-1]
                inspect_specific_element(final_result_matrix, l_rows, l_cols, "Matriz Resultante")
            else:
                print("No hay matriz de resultados disponible.")

        elif opc == '2':
            if 'effects_matrix' in locals() and effects_matrix is not None:
                l_rows = labels_sets[0]
                l_cols = labels_sets[-1]
                inspect_specific_element(effects_matrix, l_rows, l_cols, "Efectos Olvidados")
            else:
                print("No se calcularon efectos olvidados en esta ejecución.")

        elif opc == '0':
            break
        else:
            print("Opción no válida.")

    print("\nPrograma finalizado.")

    plt.show()

if __name__ == "__main__":
    main()
